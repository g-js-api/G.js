{
  "name": "@g-js-api/g.js",
  "version": "7.0.4",
  "description": "G.js - Create Geometry Dash levels (with a SPWN-like syntax) in JavaScript",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "docs": "npm run build && typedoc --options typedoc.json",
    "docs:typedoc": "typedoc --options typedoc.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "geometrydash"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/g-js-api/G.js.git"
  },
  "homepage": "https://g-js-api.github.io/G.js",
  "types": "index.d.ts",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "node-html-parser": "^6.1.10",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-pages": "^1.1.0",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^5.0.0"
  }
}
